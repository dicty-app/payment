{
  "name": "@dicty/payment",
  "version": "2.0.0",
  "description": "Dicty Stripe plugin",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/",
    "ios/Plugin/",
    "DictyPayment.podspec"
  ],
  "author": "Dicty",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wtorsi/stripe.git"
  },
  "bugs": {
    "url": "https://github.com/wtorsi/stripe/issues"
  },
  "exports": {
    ".": {
      "type": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js"
    },
    "./react": {
      "type": "./dist/esm/provider/react/PaymentPluginProvider.d.ts",
      "import": "./dist/esm/provider/react/PaymentPluginProvider.js"
    },
    "./*": "./*"
  },
  "keywords": [
    "capacitor",
    "plugin",
    "native"
  ],
  "scripts": {
    "verify": "npm run verify:ios && npm run verify:android && npm run verify:web",
    "verify:ios": "cd ios && pod install && xcodebuild -workspace Plugin.xcworkspace -scheme Plugin -destination generic/platform=iOS && cd ..",
    "verify:android": "cd android && ./gradlew clean build test && cd ..",
    "verify:web": "npm run build",
    "lint": "npm run eslint && npm run prettier -- --check && npm run swiftlint -- lint",
    "fmt": "npm run eslint -- --fix && npm run prettier -- --write && npm run swiftlint -- --fix --format",
    "eslint": "eslint . --ext ts",
    "prettier": "prettier \"**/*.{css,html,ts,js,java}\"",
    "swiftlint": "node-swiftlint",
    "docgen": "docgen --api PaymentPlugin --output-readme README.md --output-json dist/docs.json",
    "build": "npm run clean && npm run docgen && tsc && rollup -c rollup.config.js",
    "clean": "rimraf ./dist",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@capacitor/android": "^7.4.4",
    "@capacitor/core": "^7.4.4",
    "@capacitor/docgen": "^0.3.0",
    "@capacitor/ios": "^7.4.4",
    "@ionic/eslint-config": "^0.4.0",
    "@ionic/prettier-config": "^4.0.0",
    "@ionic/swiftlint-config": "^2.0.0",
    "@types/react": "^19.2.2",
    "eslint": "^9.39.0",
    "prettier": "^3.6.2",
    "prettier-plugin-java": "^2.7.7",
    "rimraf": "^6.1.0",
    "rollup": "^4.52.5",
    "swiftlint": "^2.0.0",
    "typescript": "^5.9.3",
  },
  "peerDependencies": {
    "@capacitor/core": "^5.0.4",
    "react": "^19.2.0"
  },
  "swiftlint": "@ionic/swiftlint-config",
  "eslintConfig": {
    "extends": "@ionic/eslint-config/recommended"
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  }
}
